{
    "name": "hydra/validation",
    "description": "Validation library for Hydra PHP framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hydra\\Validation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hydra\\Validation\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "William Hleucka",
            "email": "william.hleucka@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
